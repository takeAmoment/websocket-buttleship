{
    "name": "ws_task",
    "version": "1.0.0",
    "description": "Template for the WebSocket remote control task",
    "main": "index.ts",
    "type": "module",
    "scripts": {
        "build": "webpack --config webpack.config.mjs",
        "start:prod": "node dist/bundle.js",
        "clean": "rm -rf dist",
        "start:dev1": "tsx watch ./index.ts",
        "start": "npx nodemon",
        "format": "prettier --write \"src/**/*.ts\"",
        "lint": "eslint \"src/**/*.ts\" --fix",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "author": "",
    "keywords": [],
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^9.26.0",
        "@types/node": "^22.15.18",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.32.1",
        "@typescript-eslint/parser": "^8.32.1",
        "copy-webpack-plugin": "^13.0.0",
        "eslint": "^9.26.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-prettier": "^5.4.0",
        "globals": "^16.1.0",
        "nodemon": "^2.0.16",
        "prettier": "^3.5.3",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.32.1",
        "webpack": "^5.99.8",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
